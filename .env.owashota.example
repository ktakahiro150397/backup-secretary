# Docker image (shared with main instance)
HERMES_IMAGE=backup-secretary/hermes-agent:local
HERMES_BASE_IMAGE=nousresearch/hermes-agent:latest

# Host directories for the owashota instance.
# MUST be separate from the main instance to avoid data collision.
# HERMES_OWASHOTA_DATA_DIR=~/repo/backup-secretary-data/owashota/hermes-data
HERMES_WORKSPACE_DIR=./workspace
HERMES_UID=1000
HERMES_GID=1000
HERMES_READ_ONLY=false

# Gateway bind (use a different port from the main instance)
HERMES_OWASHOTA_GATEWAY_BIND=127.0.0.1
HERMES_OWASHOTA_GATEWAY_PORT=8643

# Lighter resource limits — Gemma runs on Google servers, local container is light.
HERMES_OWASHOTA_CPU_LIMIT=1
HERMES_OWASHOTA_MEMORY_LIMIT=2g
HERMES_OWASHOTA_SHM_SIZE=512m

# Do NOT put Discord tokens or LLM API keys in this Compose .env.
# Put Hermes secrets in ~/repo/backup-secretary-data/owashota/hermes-data/.env after setup.
# IMPORTANT: if running both instances with Discord, use a DIFFERENT bot token.
