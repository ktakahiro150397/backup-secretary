# Docker image. HERMES_IMAGE is the local PoC image built from HERMES_BASE_IMAGE.
HERMES_IMAGE=backup-secretary/hermes-agent:local
HERMES_BASE_IMAGE=nousresearch/hermes-agent:latest

# Host directories exposed to Hermes. Keep these inside this repository for PoC.
HERMES_DATA_DIR=./runtime/hermes-data
HERMES_WORKSPACE_DIR=./workspace
HERMES_UID=1000
HERMES_GID=1000
HERMES_READ_ONLY=false

# Local-only binds by default. Change to 0.0.0.0 only behind VPN/access control.
HERMES_GATEWAY_BIND=127.0.0.1
HERMES_GATEWAY_PORT=8642
HERMES_DASHBOARD_BIND=127.0.0.1
HERMES_DASHBOARD_PORT=9119

# Container resource limits.
HERMES_CPU_LIMIT=2
HERMES_MEMORY_LIMIT=4g
HERMES_SHM_SIZE=1g
HERMES_DASHBOARD_CPU_LIMIT=0.5
HERMES_DASHBOARD_MEMORY_LIMIT=512m

# Chrome (OpenCLI CDP bridge) settings.
CHROME_PROFILE_DIR=./runtime/chrome-profile
CHROME_CDP_BIND=127.0.0.1
CHROME_CDP_PORT=9222
CHROME_CPU_LIMIT=1
CHROME_MEMORY_LIMIT=2g
CHROME_SHM_SIZE=1g

# Do not put Discord tokens or LLM API keys in this Compose .env.
# Put Hermes secrets in runtime/hermes-data/.env after the first boot/setup.
